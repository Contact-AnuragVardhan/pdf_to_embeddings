OPENAI_API_KEY=

# Embeddings must stay text-embedding-3-large because DB uses vector(3072).
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

# LLM used only for book/chapter/language/chunking metadata detection.
# You can change this to gpt-4o-mini or gpt-5.4-mini without code changes.
OPENAI_METADATA_MODEL=gpt-5.4
AUTO_METADATA_ENABLED=true
METADATA_SAMPLE_PAGES=20
METADATA_MAX_OUTPUT_TOKENS=6000

DATABASE_URL=postgresql://user:password@localhost:5432/pdf_rag_db

# Fallback only. AUTO_CHUNKING_ENABLED lets each book choose different values.
AUTO_CHUNKING_ENABLED=true
DEFAULT_CHUNK_MAX_TOKENS=750
DEFAULT_CHUNK_OVERLAP_TOKENS=120

EMBEDDING_BATCH_SIZE=64
REINDEX_EXISTING=false
LOG_LEVEL=INFO

# After OCRmyPDF preprocessing, native text-layer extraction is preferred.
# auto_ocr/ocr are fallback modes only.
PDF_TEXT_EXTRACTION_MODE=native

# -------------------------------------------------------------------
# Production PDF text extraction / OCR preprocessing
# -------------------------------------------------------------------
# auto   = keep good selectable PDFs as-is; OCR scanned/corrupted PDFs
# always = OCR every PDF first; best when text layer is corrupted
# never  = do not run OCRmyPDF
PDF_PREPROCESS_WITH_OCRMYPDF=true
PDF_PREPROCESS_MODE=auto

# force_ocr is best for scanned books and corrupted text layers.
# redo_ocr can be used when the PDF already has an OCR layer and you want to replace it.
# skip_text keeps pages that already have text and OCRs only image-only pages.
PDF_OCRMYPDF_STRATEGY=force_ocr
PDF_OCR_CACHE_DIR=.ocr_cache

# auto = English books use eng; Hindi books use hin+eng based on --language/--medium/--subject/title.
# For English maths books, prefer eng only.
# For Hindi books, use hin+eng.
PDF_OCR_LANG=auto
PDF_OCR_DPI=300
PDF_OCR_JOBS=
PDF_OCR_OPTIMIZE=1
PDF_OCR_OUTPUT_TYPE=pdf
PDF_OCR_DESKEW=true
PDF_OCR_ROTATE_PAGES=true
PDF_OCR_CLEAN=false
PDF_OCR_INVALIDATE_CACHE=false
PDF_QUALITY_SAMPLE_PAGES=25

# -------------------------------------------------------------------
# JSON extraction artifact and page-wise console logging
# -------------------------------------------------------------------
# Creates output/json_exports/<pdf_name>_combined_extraction.json in addition to DB rows.
EXPORT_JSON_ENABLED=true
JSON_OUTPUT_DIR=output/json_exports

# Set true or pass --log-page-text to print extracted text for every page in console logs.
# For very large books this is verbose, so use --no-log-page-text or set false when needed.
LOG_EXTRACTED_PAGE_TEXT=false
LOG_PAGE_TEXT_MAX_CHARS=12000
